# Copy this file to .env and fill in your API key

GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default Gemini model
# GEMINI_MODEL=gemini-2.5-flash-lite        ← default (15 RPM, 1000 RPD free tier)
# GEMINI_MODEL=gemini-2.5-flash             ← higher quality (10 RPM, 250 RPD)
# GEMINI_MODEL=gemini-3-flash-preview       ← Gemini 3 (5 RPM, 20 RPD — tight limits)
# GEMINI_MODEL=gemini-2.5-computer-use-preview-10-2025  ← built for screen automation
